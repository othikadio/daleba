# DALEBA Core — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs

# === BASE DE DONNÉES ===
DATABASE_URL=postgresql://user:password@host:5432/daleba

# === MODÈLES IA ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# === SERVEUR ===
PORT=3000
NODE_ENV=production

# === SÉCURITÉ ===
# Mot de passe maître pour le disjoncteur d'urgence (Point 10)
DALEBA_MASTER_KEY=change-this-to-something-secret
