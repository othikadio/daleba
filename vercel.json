{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/loyalty-notify.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/auth/request-otp.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/auth/verify-otp.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/request-otp",
      "dest": "/api/auth/request-otp.js"
    },
    {
      "src": "/api/auth/verify-otp",
      "dest": "/api/auth/verify-otp.js"
    },
    {
      "src": "/api/loyalty-notify",
      "dest": "/api/loyalty-notify.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://daleba-api-production.up.railway.app/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/img/(.*)",
      "dest": "/public/img/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "^/$",
      "dest": "/public/hub.html"
    },
    {
      "src": "^/hub$",
      "dest": "/public/hub.html"
    },
    {
      "src": "^/([a-zA-Z0-9_-]+)$",
      "dest": "/public/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}