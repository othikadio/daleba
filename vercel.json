{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://daleba-api-production.up.railway.app/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/img/(.*)",
      "dest": "/public/img/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "^/$",
      "dest": "/public/hub.html"
    },
    {
      "src": "^/hub$",
      "dest": "/public/hub.html"
    },
    {
      "src": "^/([a-zA-Z0-9_-]+)$",
      "dest": "/public/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
