# ═══════════════════════════════════════════════════════════════
# DALEBA — Variables d'environnement Production
# Copier en .env.production et remplir TOUTES les valeurs
# Ne jamais commiter ce fichier complété sur Git
# ═══════════════════════════════════════════════════════════════

# ── Base de données ──────────────────────────────────────────
DATABASE_URL=postgresql://daleba:CHANGE_PASSWORD@postgres-master:5432/railway
POSTGRES_DB=railway
POSTGRES_USER=daleba
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_REPLICATION_PASSWORD=CHANGE_THIS_REPLICATION_PASSWORD

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── IA ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXX
OPENAI_API_KEY=sk-XXXXX
DEEPSEEK_API_KEY=XXXXX

# ── Square (obtenir sur developer.squareup.com) ───────────────
SQUARE_ACCESS_TOKEN=EAAA_XXXXX
SQUARE_LOCATION_ID=XXXXX

# ── Twilio (obtenir sur console.twilio.com) ───────────────────
TWILIO_ACCOUNT_SID=ACXXXXX
TWILIO_AUTH_TOKEN=XXXXX
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
ULRICH_PHONE_NUMBER=+1XXXXXXXXXX

# ── Gestion Salon — alertes SMS notation (voir src/api/gestion-routes.js) ──
# Numéros staff alertés quand une notation client est ≤3 (séparés par virgule)
GESTION_ALERT_PHONES=+15149195970,+15149845970
# Lien envoyé par SMS quand une notation client est ≥4
GESTION_GOOGLE_REVIEW_LINK=https://g.page/r/CekIGz7Cw580EBE/review

# ── Kadio RH — pointage (voir src/api/pointage-routes.js) ─────
# Numéro personnel du propriétaire pour les alertes RH (retards, absences, pauses, etc.)
OWNER_PHONE_NUMBER=+15149195970
# URL de la vidéo d'accueil employé (Module 7) — laisser vide tant que la vidéo n'existe pas
RH_VIDEO_URL=
# Heure de fermeture du salon (Module 4 — vérif tâches 30 min avant fermeture)
SALON_HEURE_FERMETURE=18:00

# ── Resend (obtenir sur resend.com/api-keys) ──────────────────
RESEND_API_KEY=re_XXXXX

# ── Stripe (obtenir sur dashboard.stripe.com) ─────────────────
STRIPE_SECRET_KEY=sk_live_XXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXX

# ── Chiffrement Vault [545] ──────────────────────────────────
# Générer: openssl rand -hex 16 (doit faire exactement 32 chars)
VAULT_ENCRYPTION_KEY=GENERATE_32_CHAR_KEY_HERE_XXXXX

# ── VPS Résilience ───────────────────────────────────────────
PRIMARY_DB_HOST=XXXXX
INSTANCE_ID=A
